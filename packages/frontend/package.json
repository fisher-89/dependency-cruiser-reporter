{
  "name": "@dcr-reporter/frontend",
  "version": "0.1.0",
  "type": "module",
  "description": "dependency-cruiser result visualizer - dependency graph, error report & metrics viewer",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc && biome check --write src/ && vp build",
    "preview": "vp preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "lint-deps": "dependency-cruiser --config .dependency-cruiser.json src/",
    "lint-deps-all": "dependency-cruiser --config .dependency-cruiser.json src/ -I",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@antv/g6": "^5.0.0-beta.28",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.45.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.3.0",
    "typescript": "^5.5.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "dist/"
  ]
}

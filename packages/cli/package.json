{
  "name": "@dcr-reporter/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI and HTTP server for dependency-cruiser-reporter",
  "bin": {
    "dep-report": "./bin/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "build:rust": "cd ../rust && cargo build --release",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "dependency-cruiser": "^17.3.0",
    "@dcr-reporter/frontend": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}

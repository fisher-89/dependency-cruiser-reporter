{
  "name": "dependency-cruiser-reporter",
  "version": "0.1.0",
  "type": "module",
  "description": "dependency-cruiser result visualizer - dependency graph, error report & metrics viewer",
  "bin": {
    "dep-report": "./bin/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && biome check --write src/ && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "lint-deps": "dependency-cruiser --config .dependency-cruiser.json src/",
    "lint-deps-all": "dependency-cruiser --config .dependency-cruiser.json src/ -I",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.45.0",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "dependency-cruiser": "^17.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": ["bin/", "dist/"]
}